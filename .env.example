# Copy this file to .env and adjust as needed. PORT and SESSION_TTL_HOURS
# have working defaults, so .env is optional for local dev — but JWT_SECRET
# should always be set explicitly before deploying anywhere real.

# Port the HTTP server listens on.
PORT=3000

# How long a login token stays valid before requiring re-authentication.
SESSION_TTL_HOURS=12

# Secret used to sign login tokens (JWT). If unset, the app falls back to a
# dev-only default and prints a warning on startup. Generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
